# ─── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://taskmaster:secret@localhost:5432/taskmaster"

# ─── Redis ──────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ─── Backend ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# ─── JWT ────────────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_long_random_string_at_least_64_chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d

# ─── Token Encryption (AES-256-GCM) ─────────────────────────────────────────────
# Generate with: openssl rand -hex 32   (or run: make gen-keys)
TOKEN_ENCRYPTION_KEY=change_me_to_64_hex_chars_32_bytes

# ─── Microsoft Entra ID (Azure AD) ──────────────────────────────────────────────
AZURE_CLIENT_ID=your-azure-app-client-id
AZURE_CLIENT_SECRET=your-azure-app-client-secret
AZURE_TENANT_ID=your-azure-tenant-id
# For multi-tenant: use "common" or "organizations" as tenant id
AZURE_REDIRECT_URI=http://localhost:3001/api/auth/microsoft/callback

# ─── Microsoft Graph Webhooks ───────────────────────────────────────────────────
# Must be publicly accessible HTTPS URL (use ngrok for local dev)
WEBHOOK_BASE_URL=https://your-ngrok-or-domain.example.com
# Random secret for Graph subscription client state validation (HMAC)
WEBHOOK_CLIENT_STATE_SECRET=change_me_to_random_secret

# ─── Daily Digest ───────────────────────────────────────────────────────────────
# Default digest time (HH:MM, 24h, local to user's timezone)
DEFAULT_DIGEST_TIME=07:30
DEFAULT_TIMEZONE=America/New_York
